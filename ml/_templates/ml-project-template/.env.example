# API Configuration
DEBUG=false
API_PORT=8000
API_HOST=0.0.0.0
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@ml-postgres:5432/mlproject

# Object Storage (MinIO)
