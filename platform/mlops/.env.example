# MLflow tracking server environment variables

# Backend store: SQLite (dev-nas) or PostgreSQL (prod-nas)
BACKEND_STORE_URI=sqlite:///mlflow/mlruns.db
# For prod-nas: postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/mlflow

# Artifact root: MinIO S3-compatible storage
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
ARTIFACT_ROOT=s3://mlflow/artifacts
