# ML Domain Infrastructure Configuration — TEMPLATE
# Copy this file to .env and fill in real values.
# The .env file is gitignored to prevent secret leakage.

# PostgreSQL
ML_POSTGRES_DB=mldb
ML_POSTGRES_USER=postgres
ML_POSTGRES_PASSWORD=replace_me_with_strong_password

# MinIO
ML_MINIO_ROOT_USER=minioadmin
ML_MINIO_ROOT_PASSWORD=replace_me_with_strong_password

# MLflow
ML_BACKEND_STORE_URI=sqlite:///mlflow/mlruns.db

# Analytics ingester — salt for SHA-256 hashing of visitor IPs.
# Generate once with: openssl rand -hex 32
# Keep stable across deploys for consistent cross-day visitor identity.
ANALYTICS_IP_SALT=replace_me_with_openssl_rand_hex_32

# Admin portal — HTTP Basic Auth credentials for /admin/
# Pick a strong password (e.g. openssl rand -base64 24).
ADMIN_USERNAME=archit
ADMIN_PASSWORD=replace_me_with_strong_password
